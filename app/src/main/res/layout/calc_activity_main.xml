<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootConstraint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- ===================== BARRA SUPERIOR (HEADER) ===================== -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:theme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="#37474F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===================== BARRA DE ÍCONES ===================== -->
    <LinearLayout
        android:id="@+id/iconBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorBackground"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@null"
            android:src="@drawable/ic_history"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Histórico" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnToggleSci"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@null"
            android:src="@drawable/ic_scientific"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Modo Científico" />

    </LinearLayout>

    <!-- ===================== DISPLAY ===================== -->
    <LinearLayout
        android:id="@+id/displayArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp"
        android:gravity="bottom|end"
        app:layout_constraintTop_toBottomOf="@id/iconBar"
        app:layout_constraintBottom_toTopOf="@id/keypadContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="20sp"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="start" />

        <TextView
            android:id="@+id/txtResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/colorTextPrimary"
            android:textSize="72sp"
            android:gravity="end"
            android:singleLine="true"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="28sp"
            android:autoSizeMaxTextSize="72sp"
            android:autoSizeStepGranularity="2sp" />
    </LinearLayout>

    <!-- ===================== KEYPAD ===================== -->
    <LinearLayout
        android:id="@+id/keypadContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="5dp"
        app:layout_constraintTop_toBottomOf="@id/displayArea"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.56">

        <!-- ===== PAINEL CIENTÍFICO ===== -->
        <LinearLayout
            android:id="@+id/scientificPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.2"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btnSin" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_sin" android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnCos" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_cos" android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnTan" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_tan" android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnPi"  style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_pi"  android:textColor="@color/colorTextScientific" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btnLog"  style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_log"  android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnLn"   style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_ln"   android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnSqrt" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_sqrt" android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnE"    style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_e"    android:textColor="@color/colorTextScientific" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btnPow"        style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_pow"        android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnOpenParen"  style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_open_paren"  android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnCloseParen" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_close_paren" android:textColor="@color/colorTextScientific" android:textSize="15sp" />
                <Button android:id="@+id/btnFactorial"  style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="3dp" android:background="@drawable/bg_button_scientific" android:text="@string/btn_factorial"  android:textColor="@color/colorTextScientific" android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== TECLADO PADRÃO ===== -->
        <LinearLayout
            android:id="@+id/standardKeypad"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btnBackspace" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_action" android:text="@string/btn_backspace" android:textColor="@color/colorTextOnAction" android:textSize="22sp" />
                <Button android:id="@+id/btnClear"     style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_action" android:text="@string/btn_clear"     android:textColor="@color/colorTextOnAction" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnPercent"   style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_action" android:text="@string/btn_percent"   android:textColor="@color/colorTextOnAction" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnDividir"   style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_operator" android:text="@string/btn_divide"  android:textColor="@color/colorTextPrimary"  android:textSize="@dimen/button_text_size" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btn7"           style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_7"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn8"           style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_8"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn9"           style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_9"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnMultiplicar" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_operator" android:text="@string/btn_multiply" android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btn4"        style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_4"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn5"        style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_5"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn6"        style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_6"        android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnSubtrair" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_operator" android:text="@string/btn_subtract" android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btn1"    style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_1"   android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn2"    style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_2"   android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn3"    style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_3"   android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnSomar" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_operator" android:text="@string/btn_add" android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                <Button android:id="@+id/btnPlusMinus" style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_plus_minus" android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btn0"         style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_0"         android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnPonto"     style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_number"   android:text="@string/btn_dot"       android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
                <Button android:id="@+id/btnIgual"     style="@style/CalcButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/bg_button_operator" android:text="@string/btn_equals"    android:textColor="@color/colorTextPrimary" android:textSize="@dimen/button_text_size" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
